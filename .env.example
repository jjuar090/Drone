# Supabase (required for get_orders and fetchandfly)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# MAVProxy connection (fetchandfly only)
# Hardware: /dev/serial0,57600
# SITL / Mission Planner: tcp:127.0.0.1:5762
# Remote Pi: tcp:192.168.x.x:5760
MASTER=tcp:127.0.0.1:5762
